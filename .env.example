# ================= AI Token Platform — sample env =================
# Copy to .env and fill with REAL values. .env is git-ignored.
# Do NOT commit real secrets. Public showcase must use fake values only.

# --- Telegram ---
BOT_TOKEN=123456789:FAKE-telegram-bot-token-from-BotFather
# The Telegram numeric user id of the single owner/admin (get it from @userinfobot)
ADMIN_TELEGRAM_ID=0
# Comma separated extra admin ids (optional)
EXTRA_ADMIN_IDS=

# --- OpenAI ---
OPENAI_API_KEY=sk-FAKE-openai-key
# Default model used until admin configures modes
DEFAULT_MODEL=gpt-4o-mini

# --- Web admin dashboard ---
# Password for the /admin web login (in addition to Telegram-id gating)
ADMIN_PANEL_PASSWORD=change-me-please
# Secret used to sign session cookies + encrypt sensitive settings.
# Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
APP_SECRET=change-me-to-a-long-random-string
WEB_HOST=0.0.0.0
WEB_PORT=8095
# Public HTTPS base URL (needed for the Telegram Mini App menu button).
# Filled automatically by scripts/start_all.ps1 when using a quick tunnel.
PUBLIC_URL=

# --- Economics (defaults, also editable from the admin panel) ---
TOKEN_UNIT_PRICE_USD=0.0005
GLOBAL_MARKUP_MULTIPLIER=1.8
MIN_CHARGE_PER_REQUEST=1
MAX_CHARGE_PER_REQUEST=100000

# --- Misc ---
DEFAULT_LANGUAGE=fa
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
